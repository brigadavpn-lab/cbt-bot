# --- Telegram ---
# Токен бота от @BotFather
BOT_TOKEN=
# Telegram ID администратора (число). При 0 — уведомления админу выключены.
ADMIN_TG_ID=0

# --- Anthropic (Claude) ---
# API-ключ из https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Webhook (опционально, можно оставить пустыми для polling-режима) ---
# Публичный URL вида https://your.domain — Telegram будет слать апдейты на $WEBHOOK_URL/webhook
WEBHOOK_URL=
# Произвольная строка-секрет для проверки заголовка X-Telegram-Bot-Api-Secret-Token
SECRET_TOKEN=generate-a-random-32-char-string-here

# --- Database (PostgreSQL) ---
# Строка подключения SQLAlchemy + asyncpg
DATABASE_URL=postgresql+asyncpg://postgres:changeme@db:5432/cbt_db
# Пароль для контейнера postgres в docker-compose
POSTGRES_PASSWORD=changeme

# --- Redis ---
# Адрес Redis для FSM-хранилища (опционально — без него используется in-memory)
REDIS_URL=redis://redis:6379/0

# --- Logging ---
LOG_LEVEL=INFO

# --- Админ-панель ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_strong_password_here
