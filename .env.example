# --- Telegram ---
BOT_TOKEN=
ADMIN_TG_ID=

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024

# --- Биллинг (Freemium) ---
FREE_LIMIT_SITUATION=5
FREE_LIMIT_GENERATOR=3
PLAN_WEEKLY_STARS=150
PLAN_WEEKLY_RUB=149
PLAN_MONTHLY_STARS=390
PLAN_MONTHLY_RUB=399

# --- YooKassa (опционально; пусто — оплата картой выключена) ---
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
PUBLIC_BASE_URL=
YUKASSA_RETURN_URL=

# --- HTTP-сервер (aiohttp, для /health и /yukassa/webhook) ---
WEB_HOST=0.0.0.0
WEB_PORT=8000

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cbt_db
DATABASE_URL=postgresql+asyncpg://postgres:changeme@db:5432/cbt_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Telegram webhook (опционально, обычно не нужен — бот работает в polling) ---
WEBHOOK_URL=
SECRET_TOKEN=

# --- Logs ---
LOG_LEVEL=INFO
LOG_FORMAT=text
USAGE_LOG_FILE=usage.log
